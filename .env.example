# Environment variables for bracket-scenarios-wc2026
#
# Copy this file to .env and fill in real values. The .env file is
# .gitignored so your secrets stay local.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your real values
#
# The framework auto-loads .env at package import via python-dotenv
# (see src/bracket_scenarios/__init__.py). For deployment, set these
# via your platform's secret manager instead of a .env file.
#
# As of v3 the framework has NO required env vars — the core pipeline
# runs from public APIs + bundled data files. The variables below are
# placeholders for v3.x+ deployment features (alerting, env overrides
# for testing, etc.) — uncomment and set when those features land.


# ── FairLine API override ────────────────────────────────────────────────────
# Override the default FairLine API endpoint. Useful for testing against
# a staging instance, or pointing at a local mock during development.
# Default: https://seal-app-yatxw.ondigitalocean.app
#
# FAIRLINE_API_URL=https://seal-app-yatxw.ondigitalocean.app


# ── Production alerting ──────────────────────────────────────────────────────
# Slack webhook for the v3 cron job to post warnings (calibration
# failures, validation regressions, etc.). When unset, the framework
# logs to stderr instead.
#
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...


# ── Future: database connection ──────────────────────────────────────────────
# If we ever persist scenarios / state history to a database instead of
# JSON files (currently no plans, but the placeholder is here for v4+).
#
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
